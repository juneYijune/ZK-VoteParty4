# ==========================================
# 匿名党内投票系统 - Git 忽略文件
# ==========================================

# ==========================================
# Node.js
# ==========================================
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
lerna-debug.log*
.pnpm-debug.log*

# ==========================================
# 环境变量和配置文件
# ==========================================
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
*.env
*.env.local

# 保留示例配置文件
!.env.example
!.env.local.example

# ==========================================
# Next.js (Frontend)
# ==========================================
frontend/.next/
frontend/out/
frontend/build/
frontend/.vercel
frontend/.turbo

# ==========================================
# Hardhat (Contracts)
# ==========================================
contracts/cache/
contracts/artifacts/
contracts/node_modules/
contracts/coverage/
contracts/coverage.json
contracts/typechain/
contracts/typechain-types/

# Hardhat 部署文件（可选择性忽略）
contracts/deployments/localhost/
contracts/deployments/hardhat/

# 保留主网和测试网部署
!contracts/deployments/mainnet/
!contracts/deployments/sepolia/
!contracts/deployments/goerli/

# ==========================================
# Backend (Express)
# ==========================================
backend/node_modules/
backend/logs/
backend/*.log
backend/dist/
backend/build/

# ==========================================
# 数据库
# ==========================================
*.sql.backup
*.db
*.sqlite
*.sqlite3

# 保留迁移文件
!backend/migrations/*.sql

# ==========================================
# IDE 和编辑器
# ==========================================
# VSCode
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
*.code-workspace

# JetBrains IDEs
.idea/
*.iml
*.iws
*.ipr
.idea_modules/

# Sublime Text
*.sublime-project
*.sublime-workspace

# Vim
*.swp
*.swo
*~

# Emacs
*~
\#*\#
.\#*

# ==========================================
# 操作系统
# ==========================================
# macOS
.DS_Store
.AppleDouble
.LSOverride
._*
.Spotlight-V100
.Trashes

# Windows
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
ehthumbs_vista.db
Desktop.ini
$RECYCLE.BIN/

# Linux
*~
.directory
.Trash-*

# ==========================================
# 日志文件
# ==========================================
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# ==========================================
# 测试覆盖率
# ==========================================
coverage/
*.lcov
.nyc_output/
.coverage/
htmlcov/
.pytest_cache/
.tox/

# ==========================================
# 临时文件
# ==========================================
tmp/
temp/
*.tmp
*.temp
*.bak
*.backup
*.cache

# ==========================================
# 构建输出
# ==========================================
dist/
build/
out/
.next/
.nuxt/
.cache/

# ==========================================
# 依赖锁文件（可选）
# ==========================================
# 如果团队使用不同的包管理器，可以忽略某些锁文件
# package-lock.json
# yarn.lock
# pnpm-lock.yaml

# ==========================================
# 密钥和敏感信息
# ==========================================
*.pem
*.key
*.cert
*.crt
*.p12
*.pfx
secrets/
private/
.secrets/

# Hardhat 私钥（重要！）
.secret
mnemonic.txt
private-key.txt

# ==========================================
# 文档和说明（可选择性忽略）
# ==========================================
# 如果不想提交某些文档
# docs/drafts/
# notes/

# ==========================================
# 其他
# ==========================================
# 压缩文件
*.zip
*.tar.gz
*.rar
*.7z

# 图片缓存
*.thumb

# 编译的二进制文件
*.exe
*.dll
*.so
*.dylib

# 调试文件
*.dSYM/
*.su
*.idb
*.pdb

# ==========================================
# 项目特定
# ==========================================
# 本地开发配置
local.config.js
local.settings.json

# 测试数据
test-data/
mock-data/

# 用户上传文件（如果有）
uploads/
public/uploads/

# 生成的文档
generated-docs/

# 性能分析
*.cpuprofile
*.heapprofile
*.heapsnapshot

# ==========================================
# Git 相关
# ==========================================
*.orig
*.rej
*.patch
