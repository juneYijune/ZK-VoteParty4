# Geth 本地私链配置示例
# 部署完成后,将合约地址填入下面,然后复制到 .env

# 数据库配置
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_password
DB_NAME=zkvote

# Redis 配置
REDIS_URL=redis://127.0.0.1:6379

# 区块链配置 - Geth 本地私链
RPC_URL=http://127.0.0.1:8558
CONTRACT_ADDRESS=

# 认证配置
WALLET_NONCE_TTL_SECONDS=300

# 注意: 后端不需要私钥!
# 所有交易都由用户通过前端 + MetaMask 发起
# 后端只负责读取区块链数据和监听事件
