# 后端环境变量示例
# 复制此文件为 .env 并填入实际值

# 数据库配置
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_password
DB_NAME=party_vote_db

# Redis 配置
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# 服务器配置
PORT=3001
NODE_ENV=development

# 区块链配置
BLOCKCHAIN_RPC_URL=http://127.0.0.1:8545
PARTY_VOTING_CONTRACT_ADDRESS=0x5FbDB2315678afecb367f032d93F642f64180aa3

# JWT 密钥（如果使用）
JWT_SECRET=your_jwt_secret_key_here

# CORS 配置
CORS_ORIGIN=http://localhost:3011
